# ==============================
# Prompt Forge Backend 环境变量示例
# 复制本文件为 .env 后按需修改真实值
# ==============================

# 运行环境: development | test | production
# 默认值: production (在 env.ts 中定义)
NODE_ENV=development

# 服务监听端口
# 默认值: 3001
PORT=3001


# ==============================
# 日志配置
# ==============================

# 日志级别 (必填): 
# fatal | error | warn | info | debug | trace | silent
# 建议: 开发环境使用 debug, 生产环境使用 info 或 warn
LOG_LEVEL=debug

# 日志文件最多保留数量 (按天滚动)
# 默认值: 90
LOG_MAX_FILES=90

# 是否删除“非当前进程创建”的日志文件
# 可选值: true | false
# 默认值: false
LOG_REMOVE_OTHER_FILES=false


# ==============================
# 数据库配置
# ==============================

# SQLite 本地文件连接串 (必填, 仅支持本地)
DATABASE_URL=prompt-forge-data/data.db


# ==============================
# Better Auth 配置
# ==============================

# 鉴权密钥 (必填, 至少 32 位)
# 生产环境请使用高强度随机字符串, 不要提交到仓库: openssl rand -base64 32
BETTER_AUTH_SECRET=

# 鉴权服务对外访问地址 (必填)
# 本地示例: 后端服务地址
BETTER_AUTH_URL=http://localhost:3001

# 禁止注册: 默认禁止
DISABLE_SIGN_UP=false

# 可信来源白名单 (可选)
# 多个来源用英文逗号分隔, 用于跨域凭证场景
# 示例: 
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ==============================
# AI Provider 配置
# ==============================

# Provider API Key 加密主密钥 (必填)
# 要求: base64 编码后解码为 32 字节.
# 生成示例: openssl rand -base64 32
AI_PROVIDER_SECRET_KEY=

# Prompt 保存草稿签名密钥 (必填)
# 用于签名 /api/saved-prompts/retry 的 saveDraft，建议使用高强度随机值
# 生成示例: openssl rand -base64 32
PROMPT_SAVE_DRAFT_SECRET=
